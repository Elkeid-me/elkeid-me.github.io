        {
            "id": "",
            "content_html": "<p>Unwrap inner type when enum variant is known. From [Stack overflow](<a href=\"https://stackoverflow.com/quest\">https://stackoverflow.com/quest</a></p>\n<br/><p>访问 <a href=\"https://elkeid-me.github.io/posts/risk/index\" target=\"_blank\">https://elkeid-me.github.io/posts/risk/index</a> 阅读全文。</p>",
            "url": "https://elkeid-me.github.io/posts/risk/index",
